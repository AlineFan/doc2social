# macOS
.DS_Store

# 备份文件
*.bak
*.bak-*

# 测试产物（可重新生成：baoyu 渲染 HTML + perbrand / baoyu 生成的图片）
test/**/*.png
test/**/*.html
test/*.html

# 内嵌 / 中间产物（可重新生成）
*-publish.html
*-fixed.html

# 产出目录里的图片（perbrand 配图 / vault 截图副本，体积大）
output/**/*.png

# perbrand 配图产物（图目录 + 生图日志；shotlist 文本可手动入库留参考）
*-illustrations/
*-illustrate.log

# baoyu skill 本地配置（含 chrome profile / SSH identity 路径等，不入库）
.baoyu-skills/

# Node/Bun（render-xshots 依赖：playwright-core + marked，可 bun install 重装）
node_modules/

# xshots 输出目录（3:4 截图，可重新生成）
xshots/
_preview.html
.gstack/
